{
  "name": "opencode-gemini-dejavu",
  "version": "0.2.1",
  "description": "OpenCode plugin that mitigates Gemini 3.x repeated tool-call deja vu with request-local turn boundaries.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/isac322/opencode-gemini-dejavu.git"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "gemini",
    "gemini-3",
    "agent",
    "tool-call-loop",
    "repeated-tool-calls"
  ],
  "type": "module",
  "main": "./dist/plugin.js",
  "types": "./dist/plugin.d.ts",
  "exports": {
    ".": {
      "types": "./dist/plugin.d.ts",
      "default": "./dist/plugin.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18.17"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "typecheck": "tsgo --noEmit",
    "check": "biome check .",
    "test": "bun test-fixture.ts fixtures/minimal-loop && bun test-hook.ts fixtures/minimal-loop",
    "test:fixture": "bun test-fixture.ts",
    "test:hook": "bun test-hook.ts",
    "prepublishOnly": "bun run typecheck && bun run check && bun run test && bun run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@opencode-ai/plugin": "^1.15.12",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "@typescript/native-preview": "^7.0.0-dev.20260527.2"
  }
}
